{
  "name": "pixi-skia-wrapper",
  "version": "1.0.0",
  "description": "TypeScript wrapper to render Pixi.js containers with Skia CanvasKit and export to PDF",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "vendor/canvaskit-wasm"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && node scripts/postbuild.js",
    "dev:example": "npm -C example run dev",
    "build:example": "npm -C example run build",
    "preview:example": "npm -C example run preview",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,scss}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "pixi.js-legacy": "^7.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "husky": "^9.1.5",
    "jsdom": "^24.1.0",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "sass": "^1.77.8",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "src/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
